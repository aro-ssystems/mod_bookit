{{!
    @template mod_bookit/event_checklist_catalog
    Event checklist catalog template

    Context variables:
    * eventid   - Event ID
    * cmid      - Course module ID
    * canmanage - 1 if user can manage status, 0 otherwise
    * contextid - Context ID
    * eventname - Event title
    * starttime - Formatted start time string
    * endtime   - Formatted end time string
    * categories - Array of category objects, each with items array
    * hasresources - Boolean: any resources assigned?

    Example context (json):
    {
        "eventid": 1,
        "cmid": 4,
        "canmanage": 1,
        "contextid": 1,
        "eventname": "Test Event",
        "starttime": "24 Feb 2026, 10:00",
        "endtime": "24 Feb 2026, 12:00",
        "hasresources": true,
        "categories": [
            {
                "id": 1,
                "name": "Technik",
                "items": [
                    {
                        "id": 1,
                        "resourceid": 1,
                        "resourcename": "Beamer",
                        "categoryid": 1,
                        "amount": 2,
                        "status": "requested",
                        "duedate": "20 Feb 2026",
                        "canmanage": 1,
                        "isrequested": true,
                        "isconfirmed": false,
                        "isinprogress": false,
                        "isrejected": false
                    }
                ]
            }
        ]
    }
}}
<div class="d-flex justify-content-center">
<div id="mod-bookit-event-checklist-container"
     class="mod-bookit-event-checklist-container mt-4 pr-5 mr-5"
     data-region="event-checklist-container"
     data-eventid="{{eventid}}"
     data-cmid="{{cmid}}"
     data-canmanage="{{canmanage}}"
     data-contextid="{{contextid}}"
     style="min-width: 784px;">

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">{{#str}}event_details, mod_bookit{{/str}}</h5>
            <dl class="row mb-0">
                <dt class="col-sm-3">{{#str}}event_name, mod_bookit{{/str}}</dt>
                <dd class="col-sm-9">{{{eventname}}}</dd>
                {{#starttime}}
                <dt class="col-sm-3">{{#str}}starttime, mod_bookit{{/str}}</dt>
                <dd class="col-sm-9">{{starttime}}</dd>
                {{/starttime}}
                {{#roomname}}
                <dt class="col-sm-3">{{#str}}event_room, mod_bookit{{/str}}</dt>
                <dd class="col-sm-9">{{roomname}}</dd>
                {{/roomname}}
                {{#bookingstatus}}
                <dt class="col-sm-3">{{#str}}event_bookingstatus, mod_bookit{{/str}}</dt>
                <dd class="col-sm-9">{{bookingstatus}}</dd>
                {{/bookingstatus}}
            </dl>
        </div>
    </div>

    {{#hasresources}}
    <table class="table table-borderless table-hover bg-white rounded w-100" id="event-checklist-table">
                <thead class="bg-primary text-light border-bottom" style="opacity: 0.5;">
                    <tr>
                        <th scope="col" class="py-3 font-weight-bold">{{#str}}resource, mod_bookit{{/str}}</th>
                        <th scope="col" class="py-3 font-weight-bold text-center" style="width: 90px;">{{#str}}resources:amount, mod_bookit{{/str}}</th>
                        <th scope="col" class="py-3 font-weight-bold text-center" style="width: 90px;">{{#str}}event_checklist:booked_amount, mod_bookit{{/str}}</th>
                        <th scope="col" class="py-3 font-weight-bold" style="width: 150px;">{{#str}}duedate, mod_bookit{{/str}}</th>
                        <th scope="col" class="py-3 font-weight-bold" style="width: 180px;">{{#str}}resource_status, mod_bookit{{/str}}</th>
                    </tr>
                </thead>
                {{#categories}}
                <tbody data-region="event-checklist-category"
                       data-categoryid="{{id}}">
                    <tr class="table-active bg-light border-bottom" data-region="event-checklist-category-row">
                        <td colspan="5" class="font-weight-bold text-dark py-3">{{{name}}}</td>
                    </tr>
                    {{#items}}
                    {{> mod_bookit/event_checklist_item_row }}
                    {{/items}}
                </tbody>
                {{/categories}}
            </table>
    {{/hasresources}}
    {{^hasresources}}
    <div class="alert alert-info">
        {{#str}}event_checklist_no_resources, mod_bookit{{/str}}
    </div>
    {{/hasresources}}

</div>
</div>
